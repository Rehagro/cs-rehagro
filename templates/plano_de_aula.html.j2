<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Plano de Aula — {{ aluno.nome }}</title>
{# Fontes embutidas (base64) — documento self-contained, sem depender de rede.
   Injetado por core.render_plano.render_html. #}
{{ font_face_css | safe }}
<style>
  /* ===== RESET / PAGE ===== */
  * { box-sizing: border-box; }
  body { margin: 0; background: #E7EBE6; font-family: 'Mulish', system-ui, sans-serif; color: #1B2B22; -webkit-font-smoothing: antialiased; }
  a { color: inherit; }

  /* ===== DOCUMENT FRAME (margens repetidas por página via thead/tfoot) ===== */
  .doc { box-sizing: border-box; max-width: 820px; margin: 24px auto; background: #fff; padding: 32px clamp(16px,4vw,42px) 36px; box-shadow: 0 10px 40px rgba(14,58,41,.14); }
  .doc-frame { width: 100%; border-collapse: collapse; }
  .doc-frame td { padding: 0; }
  .hdr-space, .ftr-space { display: none; }

  @page { size: A4; margin: 0; }
  @media print {
    html { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    html, body { margin: 0; padding: 0; background: #fff; }
    .doc { max-width: none !important; margin: 0 !important; padding: 0 0.5in !important; box-shadow: none !important; }
    .hdr-space, .ftr-space { display: table-cell; height: 0.38in; }
    .module-card, .welcome-card, .closing-card, .hero { break-inside: avoid; }
    h1, h2, h3 { break-after: avoid; }
  }
</style>
</head>
<body>
<main class="doc">
  <table class="doc-frame" role="presentation">
    <thead><tr><td class="hdr-space"></td></tr></thead>
    <tbody><tr><td>

      <!-- ===================== HERO / CAPA ===================== -->
      <section class="hero" style="position:relative; overflow:hidden; border-radius:18px; background:linear-gradient(135deg,#0F4630 0%,#0C3624 45%,#071E15 100%); padding:24px 30px 22px;">
        <svg viewBox="0 0 400 400" style="position:absolute; top:-130px; right:-120px; width:360px; height:360px; opacity:.9;" aria-hidden="true">
          <circle cx="200" cy="200" r="180" fill="none" stroke="#C49A45" stroke-width="2.5" opacity="0.55"></circle>
          <circle cx="200" cy="200" r="150" fill="none" stroke="#C49A45" stroke-width="1.2" opacity="0.3"></circle>
        </svg>
        <svg viewBox="0 0 200 200" style="position:absolute; bottom:-80px; left:-60px; width:160px; height:160px; opacity:.5;" aria-hidden="true">
          <circle cx="100" cy="100" r="80" fill="none" stroke="#1E7A45" stroke-width="22" opacity="0.45"></circle>
        </svg>

        <div style="position:relative; display:flex; align-items:center; justify-content:space-between; gap:16px;">
          <img src="{{ logo_url }}" alt="Rehagro" style="height:23px; width:auto; display:block;">
          <span style="font-family:'Poppins',sans-serif; font-size:10px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#E0C06A; border:1px solid rgba(224,192,106,.45); padding:5px 11px; border-radius:999px; white-space:nowrap;">Sucesso do Cliente</span>
        </div>

        <div style="position:relative; margin-top:20px;">
          <div style="font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; letter-spacing:.2em; text-transform:uppercase; color:#E0C06A;">Plano de Aula Personalizado</div>
          <h1 style="font-family:'Poppins',sans-serif; font-weight:700; font-size:31px; line-height:1.05; color:#fff; margin:7px 0 0; letter-spacing:-.01em;">{{ aluno.nome }}</h1>
          <div style="display:flex; flex-wrap:wrap; align-items:center; gap:6px 14px; margin-top:13px; color:rgba(255,255,255,.78); font-size:12.5px; font-weight:500;">
            <span style="display:inline-flex; align-items:center; gap:7px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E0C06A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v13.5"></path><path d="M4 19.5h16"></path><path d="M9 8h6M9 12h6"></path></svg>
              {{ curso.nome }}
            </span>
            <span style="opacity:.4;">•</span>
            <span style="display:inline-flex; align-items:center; gap:7px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E0C06A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
              Gerado em {{ data_geracao }}
            </span>
          </div>
        </div>
      </section>

      <!-- ===================== INTRO ===================== -->
      <p style="font-size:13.5px; line-height:1.6; color:#33433A; margin:18px 2px 4px;">
        <strong style="color:#0F4630;">{{ aluno.nome }}</strong>, esse é o seu plano de aula, personalizado de acordo com os seus principais desafios. <strong style="color:#0F4630;">Recomendamos que seus estudos sigam a sequência de módulos abaixo.</strong> Confira sua recomendação:
      </p>

      <!-- ===================== PARA COMEÇAR ===================== -->
      <div style="display:flex; align-items:center; gap:14px; margin:22px 0 12px;">
        <h2 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:#0F4630; margin:0; white-space:nowrap;">Para começar</h2>
        <span style="flex:1; height:2px; background:linear-gradient(90deg,#C49A45 0%, #E7EBE6 100%); border-radius:2px;"></span>
      </div>

      <div class="welcome-card" style="position:relative; border:1px solid #E2EAE4; border-radius:14px; padding:16px 20px; background:linear-gradient(180deg,#FBFAF4 0%,#FFFFFF 60%);">
        <div style="display:flex; align-items:flex-start; gap:15px;">
          <div style="flex:none; width:44px; height:44px; border-radius:12px; background:linear-gradient(135deg,#1E7A45,#0F4630); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 12px rgba(15,70,48,.25);">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V4l9 4-9 4"></path><path d="M13 8h7v8a2 2 0 0 1-2 2H4"></path></svg>
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-family:'Poppins',sans-serif; font-size:10px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:#C49A45;">Início</div>
            <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:17px; color:#0F4630; margin:3px 0 5px;">{{ boas_vindas.titulo }}</h3>
            <p style="font-size:13px; line-height:1.55; color:#445349; margin:0 0 12px;">{{ boas_vindas.descricao }}</p>
            <a href="{{ boas_vindas.url }}" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; background:#0F4630; color:#fff; font-family:'Poppins',sans-serif; font-weight:500; font-size:12.5px; padding:8px 14px; border-radius:9px;">
              Acessar módulo
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E0C06A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"></path></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- ===================== TRILHA ===================== -->
      <div style="display:flex; align-items:center; gap:14px; margin:24px 0 6px;">
        <h2 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:#0F4630; margin:0; white-space:nowrap;">Sua trilha personalizada</h2>
        <span style="flex:1; height:2px; background:linear-gradient(90deg,#C49A45 0%, #E7EBE6 100%); border-radius:2px;"></span>
      </div>
      <p style="font-size:12.5px; line-height:1.5; color:#6A776E; margin:0 2px 14px;">A sua trilha apresenta os 3 módulos principais para sanar suas maiores dores e desafios, de acordo com as respostas de sua pesquisa.</p>

      {# ===== LOOP DE MÓDULOS — repete um card por item em `modulos` ===== #}
      {% for m in modulos %}
      <div class="module-card" style="border:1px solid #E2EAE4; border-radius:15px; overflow:hidden; margin-bottom:13px; box-shadow:0 2px 10px rgba(15,70,48,.05);">
        <div style="display:flex; align-items:center; gap:14px; padding:13px 18px; background:linear-gradient(180deg,#F4F8F4,#FFFFFF);">
          <div style="flex:none; width:46px; height:46px; border-radius:50%; background:linear-gradient(135deg,#E6C977,#C49A45); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 12px rgba(196,154,69,.35);">
            <span style="font-family:'Poppins',sans-serif; font-weight:700; font-size:19px; color:#fff;">{{ loop.index }}</span>
          </div>
          <div style="flex:1; min-width:0;">
            <span style="display:inline-block; font-family:'Poppins',sans-serif; font-size:9.5px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#9A7626; background:#FBF3DE; padding:3px 9px; border-radius:999px;">{{ loop.index }}ª Prioridade</span>
            <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:17px; color:#0F4630; margin:5px 0 0; line-height:1.2;">{{ m.titulo }}</h3>
          </div>
        </div>
        <div style="padding:2px 18px 16px;">
          <p style="font-size:13px; line-height:1.55; color:#445349; margin:0 0 11px;">{{ m.descricao }}</p>
          <a href="{{ m.url }}" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; border:1.5px solid #1E7A45; color:#0F4630; font-family:'Poppins',sans-serif; font-weight:500; font-size:12.5px; padding:7px 13px; border-radius:9px; margin-bottom:13px;">
            Acessar módulo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1E7A45" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"></path></svg>
          </a>

          <div style="background:#F3F7F3; border-radius:12px; padding:14px 16px;">
            <div style="font-family:'Poppins',sans-serif; font-size:10px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:#1E7A45; margin-bottom:11px;">Materiais de aula</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:11px;">
              <div style="background:#fff; border:1px solid #E2EAE4; border-radius:10px; padding:10px 13px; display:flex; align-items:center; gap:11px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C49A45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="14" rx="2"></rect><path d="M10 9l4 2-4 2V9z" fill="#C49A45" stroke="none"></path></svg>
                <div><div style="font-family:'Poppins',sans-serif; font-weight:700; font-size:18px; color:#0F4630; line-height:1;">{{ m.qtd_aulas }}</div><div style="font-size:11px; color:#6A776E; margin-top:2px;">videoaulas</div></div>
              </div>
              <div style="background:#fff; border:1px solid #E2EAE4; border-radius:10px; padding:10px 13px; display:flex; align-items:center; gap:11px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C49A45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                <div><div style="font-family:'Poppins',sans-serif; font-weight:700; font-size:18px; color:#0F4630; line-height:1;">{{ m.tempo_aula }}</div><div style="font-size:11px; color:#6A776E; margin-top:2px;">de aula gravada</div></div>
              </div>
            </div>
            <div style="display:flex; align-items:flex-start; gap:10px; padding:8px 0; border-top:1px solid #E2EAE4;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E7A45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none; margin-top:1px;"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
              <div style="font-size:12.5px; line-height:1.5; color:#445349;"><strong style="color:#0F4630;">Atividades:</strong> {{ m.atividades }}</div>
            </div>
            <div style="display:flex; align-items:flex-start; gap:10px; padding:8px 0 0; border-top:1px solid #E2EAE4;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E7A45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none; margin-top:1px;"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
              <div style="font-size:12.5px; line-height:1.5; color:#445349;"><strong style="color:#0F4630;">Programação:</strong> {{ m.programacao }}</div>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}

      <!-- ===================== ENCERRAMENTO ===================== -->
      <div class="closing-card" style="position:relative; overflow:hidden; border-radius:15px; background:linear-gradient(135deg,#0F4630 0%,#0A2C1E 100%); padding:20px 24px; margin-top:16px;">
        <svg viewBox="0 0 200 200" style="position:absolute; bottom:-90px; right:-50px; width:180px; height:180px; opacity:.5;" aria-hidden="true"><circle cx="100" cy="100" r="80" fill="none" stroke="#C49A45" stroke-width="2"></circle></svg>
        <div style="position:relative;">
          <p style="font-size:13.5px; line-height:1.6; color:#EAF1EC; margin:0 0 14px; max-width:560px;">{{ encerramento.mensagem }}</p>
          <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding-top:14px; border-top:1px solid rgba(255,255,255,.14);">
            <div style="display:flex; align-items:center; gap:12px;">
              <div style="flex:none; width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,#E6C977,#C49A45); display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:700; color:#0F4630; font-size:14px;">CS</div>
              <div>
                <div style="font-family:'Poppins',sans-serif; font-weight:600; font-size:13.5px; color:#fff;">{{ encerramento.equipe }}</div>
                <div style="font-size:12px; color:#A9C2B2;">{{ encerramento.organizacao }}</div>
              </div>
            </div>
            {% if encerramento.whatsapp_url %}
            <a href="{{ encerramento.whatsapp_url }}" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; background:#25D366; color:#fff; font-family:'Poppins',sans-serif; font-weight:600; font-size:12.5px; padding:9px 15px; border-radius:9px; white-space:nowrap; box-shadow:0 4px 12px rgba(37,211,102,.25);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              Falar no WhatsApp
            </a>
            {% endif %}
          </div>
        </div>
      </div>

    </td></tr></tbody>
    <tfoot><tr><td class="ftr-space"></td></tr></tfoot>
  </table>
</main>
</body>
</html>
